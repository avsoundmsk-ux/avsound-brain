# Воркер генераций (pg-boss → ModelArk → settle/refund). Не Next, отдельный процесс.
FROM node:22-slim
WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev || npm install --omit=dev
# tsx нужен в рантайме воркера
RUN npm install tsx
COPY . .
ENV NODE_ENV=production
CMD ["npx", "tsx", "src/worker/index.ts"]
