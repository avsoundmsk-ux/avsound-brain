# --- База данных (Neon рекомендую: бесплатно, serverless) ---
DATABASE_URL=postgres://user:pass@host/db

# --- Auth ---
BETTER_AUTH_SECRET=            # длинная случайная строка
BETTER_AUTH_URL=http://localhost:3000

# --- Email (verify/reset): Resend/SendGrid SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=AV AI Studio <no-reply@av-sound.ru>

# --- Платежи ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Хранилище (S3-совместимое: Cloudflare R2 / Backblaze B2) ---
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE=

# --- AI провайдеры (ядро ai-hub) ---
KIE_API_KEY=
MODELARK_API_KEY=
MODELARK_BASE_URL=https://ark.ap-southeast.bytepluses.com

# --- Прочее ---
NODE_ENV=development
